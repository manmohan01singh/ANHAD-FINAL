# ═══════════════════════════════════════════════════════════
# ANHAD Backend Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development

# Cloudflare R2 Audio Storage
R2_BASE_URL=https://pub-525228169e0c44e38a67c306ba1a458c.r2.dev

# CORS — comma-separated allowed origins
# For production on Render, add your Vercel domain:
# ALLOWED_ORIGINS=https://anhadnaam.vercel.app,capacitor://localhost,ionic://localhost
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,capacitor://localhost,ionic://localhost

# File Paths (optional - defaults work for most deployments)
# FRONTEND_ROOT=../frontend
# MAIN_UI=../frontend
# SEHAJ_PROGRESS_DIR=./data/sehaj-progress
# RADIO_STATE_FILE=./radio-state.json

# Radio Configuration (optional - defaults are fine)
# DEFAULT_TRACK_DURATION=3600
# LISTENER_TTL=60000
# STATE_SAVE_INTERVAL=30000
