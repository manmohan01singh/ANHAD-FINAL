  "quotes": [
    {
      "text": "ਅੰਮ੍ਰਿਤ ਵੇਲਾ ਸਚੁ ਨਾਉ ਵਡਿਆਈ ਵੀਚਾਰੁ ॥",
      "transliteration": "Amrit velā sach nāu vadiāī vīchār",
      "translation": "In the Amrit Vela, the ambrosial hours before dawn, chant the True Name, and contemplate His Glorious Greatness.",
      "source": "Japji Sahib",
      "author": "Guru Nanak Dev Ji"
    },
    {
      "text": "ਪ੍ਰਭਾਤੀ ਪ੍ਰਭੁ ਨਾਮੁ ਲੈ ਦਿਨੁ ਸਫਲੁ ਤਿਥਿ ॥",
      "transliteration": "Prabhātī prabh nām lai din safal tith",
      "translation": "Reciting God's Name at dawn makes the day fruitful.",
      "source": "Sri Guru Granth Sahib Ji",
      "author": "Guru Arjan Dev Ji"
    },
    {
      "text": "ਗੁਰ ਸਤਿਗੁਰ ਕਾ ਜੋ ਸਿਖੁ ਅਖਾਏ ਸੁ ਭਲਕੇ ਉਠਿ ਹਰਿ ਨਾਮੁ ਧਿਆਵੈ ॥",
      "transliteration": "Gur satgur kā jo sikh akhāe su bhalkē uth har nām dhiāvai",
      "translation": "One who calls himself a Sikh of the True Guru shall rise early and meditate on the Lord's Name.",
      "source": "Rehras Sahib",
      "author": "Guru Ram Das Ji"
    },
    {
      "text": "ਨਾਨਕ ਨਾਮੁ ਮਿਲੈ ਤਾਂ ਜੀਵਾਂ ਤਨੁ ਮਨੁ ਥੀਵੈ ਹਰਿਆ ॥",
      "transliteration": "Nānak nām milai tāṁ jīvāṁ tan man thīvai hariā",
      "translation": "O Nanak, if I receive the Naam, I live; my body and mind blossom forth.",
      "source": "Anand Sahib",
      "author": "Guru Amar Das Ji"
    },
    {
      "text": "ਦੇਹਿ ਸ਼ਿਵਾ ਬਰ ਮੋਹਿ ਇਹੈ ਸ਼ੁਭ ਕਰਮਨ ਤੇ ਕਬਹੂੰ ਨ ਟਰੋਂ ॥",
      "transliteration": "Deh shivā bar mohi ihai shubh karman te kabhūṁ na ṭaroṁ",
      "translation": "O Lord, grant me this boon: that I may never deviate from doing good deeds.",
      "source": "Chandi Charitar",
      "author": "Guru Gobind Singh Ji"
    }
  ],
