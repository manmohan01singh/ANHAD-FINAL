{
    "quotes": [
        {
            "gurmukhi": "ਸਤਿਨਾਮੁ ਕਰਤਾ ਪੁਰਖੁ",
            "transliteration": "Satnam Karta Purakh",
            "translation": "True Name, Creative Being"
        },
        {
            "gurmukhi": "ਵਾਹਿਗੁਰੂ ਜੀ ਕਾ ਖਾਲਸਾ",
            "transliteration": "Waheguru Ji Ka Khalsa",
            "translation": "The Khalsa belongs to God"
        },
        {
            "gurmukhi": "ਵਾਹਿਗੁਰੂ ਜੀ ਕੀ ਫਤਹਿ",
            "transliteration": "Waheguru Ji Ki Fateh",
            "translation": "Victory belongs to God"
        },
        {
            "gurmukhi": "ਜਪੁ ਤਪੁ ਸੰਜਮੁ ਧਰਮੁ ਨ ਕਮਾਇਆ",
            "transliteration": "Jap Tap Sanjam Dharam Na Kamaaya",
            "translation": "Meditation, austerity, self-discipline and righteous conduct"
        },
        {
            "gurmukhi": "ਏਕੋ ਨਾਮੁ ਹੁਕਮੁ ਹੈ",
            "transliteration": "Eko Naam Hukam Hai",
            "translation": "The One Name is the Command"
        }
    ]
}