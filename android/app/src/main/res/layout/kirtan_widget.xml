<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/kirtan_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical">

    <!-- Icon -->
    <TextView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="🎵"
        android:textSize="28sp"
        android:gravity="center"
        android:background="@drawable/circle_accent_bg"
        android:layout_marginEnd="12dp" />

    <!-- Track Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/kirtan_track"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not Playing"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/kirtan_station"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Station"
            android:textSize="12sp"
            android:textColor="#B3FFFFFF"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/kirtan_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏸ Paused"
            android:textSize="11sp"
            android:textColor="#FF9500"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>
